# Server
PORT=7000
SERVER_URL=http://127.0.0.1:7000

# Redis
REDIS_ADDR=redis:6379

# Metadata provider (ANILIST or ALL_ANIME)
METADATA_PROVIDER=ANILIST

# Stream providers (comma separated)
SOURCE_PROVIDERS=ALL_ANIME

# AniList OAuth Client ID
# Create at https://anilist.co/settings/developer
# Redirect URL: {SERVER_URL}/configure
ANILIST_CLIENT_ID=

# IdsMoe API KEY
# Required only for Kitsu catalog support
IDS_MOE_API_KEY=
