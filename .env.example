# Server
PORT=7000
SERVER_URL=http://127.0.0.1:7000

# Metadata provider (ANILIST or ALL_ANIME)
METADATA_PROVIDER=ANILIST

# Stream providers (ALL_ANIME) (comma separated)
SOURCE_PROVIDERS=ALL_ANIME

# AniList OAuth Client ID
# Create at https://anilist.co/settings/developer
# Set the redirect URL to: {SERVER_URL}/configure
# Optional: Only Required for Anilist Watchlist Sync
ANILIST_CLIENT_ID=

# IdsMoe API KEY
# Create a API KEY at https://ids.moe/
# Optional: Only Required if Kitsu Catalog Support Needed
IDS_MOE_API_KEY=
